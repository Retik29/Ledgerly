datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String            @id @default(uuid())
  name         String
  email        String            @unique
  passwordHash String
  createdAt    DateTime          @default(now())
  
  // Relations
  createdGroups      Group[]            @relation("GroupCreator")
  memberships        GroupMembership[]
  paidExpenses       Expense[]          @relation("ExpensePayer")
  paidSettlements    Settlement[]       @relation("SettlementPayer")
  receivedSettlements Settlement[]      @relation("SettlementReceiver")
  expenseShares      ExpenseParticipant[]
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())
  
  // Relations
  creator     User              @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  memberships GroupMembership[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMembership {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  joinedAt DateTime
  leftAt   DateTime?
  
  // Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId, joinedAt])
}

model Expense {
  id               String               @id @default(uuid())
  groupId          String
  title            String
  description      String?
  amount           Float
  currency         String               @default("INR")
  exchangeRate     Float                @default(1.0)
  normalizedAmount Float
  paidBy           String
  expenseDate      DateTime
  splitType        String               // equal, percentage, exact, share, weight
  imported         Boolean              @default(false)
  createdAt        DateTime             @default(now())
  deletedAt        DateTime?
  
  // Relations
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                 @relation("ExpensePayer", fields: [paidBy], references: [id], onDelete: Cascade)
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id              String   @id @default(uuid())
  expenseId       String
  userId          String
  sharePercentage Float?
  shareAmount     Float
  shareWeight     Float?
  
  // Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id             String    @id @default(uuid())
  groupId        String
  payerId        String
  receiverId     String
  amount         Float
  currency       String    @default("INR")
  settlementDate DateTime
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  
  // Relations
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Cascade)
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id           String          @id @default(uuid())
  rawFileName  String
  rawFileHash  String
  status       String          // UPLOADED, ANALYZING, REVIEW_REQUIRED, APPROVED, IMPORTING, COMPLETED, FAILED
  uploadedAt   DateTime        @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  summary      String?         // SQLite does not support JSON, so we store it as a JSON string
  
  // Relations
  anomalies ImportAnomaly[]
}

model ImportAnomaly {
  id                String    @id @default(uuid())
  importJobId       String
  rowNumber         Int
  fingerprint       String
  severity          String    // INFO, WARNING, ERROR, BLOCKING
  anomalyType       String
  description       String
  rawRow            String    // SQLite does not support JSON, so store as JSON string
  normalizedRow     String?   // JSON string
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED, RESOLVED
  resolvedBy        String?
  resolvedAt        DateTime?
  resolutionNote    String?
  policyType        String?   // DUPLICATE, CURRENCY, SETTLEMENT, MEMBERSHIP
  policyVersion     Int?
  resolutionAction  String?   // MAPPED_USER, APPROVED_DUPLICATE, REJECTED_ROW, CONVERTED_TO_SETTLEMENT, ACCEPTED_WARNING
  
  // Relations
  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  performedBy String?
  beforeState String?  // JSON string
  afterState  String?  // JSON string
  createdAt   DateTime @default(now())
}
